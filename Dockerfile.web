# ─────────────────────────────────────────────────────────────────────────────
# Stage 1: pnpm install + next build
# ─────────────────────────────────────────────────────────────────────────────
FROM public.ecr.aws/docker/library/node:22-slim AS builder

RUN npm install -g pnpm

WORKDIR /app/web

# Copy manifests first (layer-cache-friendly)
COPY web/package.json web/pnpm-lock.yaml* ./

# pnpm-lock.yaml이 없을 수도 있으므로 --no-frozen-lockfile 사용
RUN pnpm install --no-frozen-lockfile

# Copy the rest of the web source (engine/skins are inside web/)
COPY web/ ./

RUN pnpm build

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: 결과물만 추출
# (docker build --target export --output type=local,dest=... 으로 꺼냄)
# ─────────────────────────────────────────────────────────────────────────────
FROM scratch AS export
COPY --from=builder /app/web/out/ /
