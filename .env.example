# piLoci Environment Variables
# Copy to .env and fill in values. Never commit .env.

# === Secrets ===
# Docker Compose production loads these automatically from /run/secrets via
# JWT_SECRET_FILE and SESSION_SECRET_FILE. For local/native runs, uncomment and set:
# JWT_SECRET=change-me-generate-with-secrets-token-hex-32
# SESSION_SECRET=change-me-generate-with-secrets-token-hex-32

# === Database ===
DATABASE_URL=sqlite+aiosqlite:////data/piloci.db

# === LanceDB ===
LANCEDB_PATH=/data/lancedb

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Embedding ===
EMBED_MODEL=BAAI/bge-small-en-v1.5
# EMBED_CACHE_DIR=/data/embed_cache

# === Server ===
HOST=0.0.0.0
PORT=8314
LOG_LEVEL=INFO
LOG_FORMAT=json
# WORKERS=4  # uvicorn workers (default: 1 in dev, 4 in prod)

# === Low-spec mode (Pi 5) ===
# LOW_SPEC_MODE=true  # clamps workers, cache, concurrency, queue to Pi-safe defaults

# === Retention / ops ===
# RAW_SESSION_RETENTION_DAYS=30
# AUDIT_LOG_RETENTION_DAYS=90
# MAINTENANCE_INTERVAL_SEC=600

# === SQLite tuning ===
# SQLITE_BUSY_TIMEOUT_MS=5000
# SQLITE_SYNCHRONOUS=NORMAL

# === Optional: SMTP (email verification / password reset) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@email.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@piloci.example.com

# === Optional: Google OAuth ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === Optional: Telegram session alerts ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_MIN_DURATION_SEC=300
# TELEGRAM_MIN_MEMORY_OPS=1
# TELEGRAM_TIMEOUT_SEC=10

# === Optional: Cloudflare Tunnel ===
# docker-compose.yml reads /run/secrets/tunnel_token automatically when present.

# === Dev only ===
DEBUG=false
RELOAD=false
